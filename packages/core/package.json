{
  "name": "@pvotly/core",
  "version": "0.1.0",
  "description": "Framework-agnostic pivot table engine: data model, aggregation, filtering, sorting, formatting and calculated measures. Zero dependencies.",
  "license": "MIT",
  "author": "pvotly contributors",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "keywords": [
    "pivot",
    "pivot-table",
    "pivot-grid",
    "olap",
    "aggregation",
    "data-analysis",
    "report",
    "crosstab"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/artainjast/pivot-table",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  }
}
