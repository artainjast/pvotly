{
  "name": "@pvotly/react",
  "version": "0.1.0",
  "description": "React wrapper for pvotly — a declarative <PivotTable /> component with hooks and refs.",
  "license": "MIT",
  "author": "pvotly contributors",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "keywords": ["pivot", "pivot-table", "react", "react-component", "data-grid", "olap"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pvotly/core": "workspace:*",
    "@pvotly/web": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/artainjast/pivot-table",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  }
}
